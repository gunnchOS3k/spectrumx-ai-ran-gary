{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/spectrumx-gary/ota_capture_record.schema.json",
  "title": "OTACaptureRecord",
  "type": "object",
  "required": [
    "capture_id",
    "site_id",
    "center_freq_hz",
    "sample_rate_hz",
    "duration_s",
    "antenna_config"
  ],
  "properties": {
    "capture_id": { "type": "string" },
    "site_id": { "type": "string", "description": "Gary anchor id, e.g. public_library" },
    "center_freq_hz": { "type": "number" },
    "sample_rate_hz": { "type": "number" },
    "duration_s": { "type": "number" },
    "antenna_config": { "type": "string" },
    "gps_lat": { "type": ["number", "null"] },
    "gps_lon": { "type": ["number", "null"] },
    "weather_tag": { "type": ["string", "null"] },
    "interference_tags": { "type": "array", "items": { "type": "string" } },
    "detector_label_at_capture": { "type": ["integer", "null"] },
    "ground_truth_label": { "type": ["integer", "null"] },
    "calibration_offset_db": { "type": ["number", "null"] },
    "iq_npy_relative_path": { "type": "string", "description": "Path relative to data/ota_evidence/" },
    "notes": { "type": ["string", "null"] }
  },
  "additionalProperties": true
}
